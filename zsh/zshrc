[[ "$TERM_PROGRAM" == "vscode" ]] && eval "$(~/.local/bin/agent shell-integration zsh)"
# Resolve dotfiles path from this symlink
DOTFILES_ZSH="$(dirname "$(readlink -f "$HOME/.zshrc")")"

# Load all .zsh files from dotfiles
for file in "$DOTFILES_ZSH"/*.zsh; do
  source "$file"
done

# Local overrides (gitignored)
[[ -f "$DOTFILES_ZSH/local.zsh" ]] && source "$DOTFILES_ZSH/local.zsh"

# bun completions
[ -s "/Users/ivan_kalinichenko/.bun/_bun" ] && source "/Users/ivan_kalinichenko/.bun/_bun"

# pnpm
export PNPM_HOME="/Users/ivan_kalinichenko/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end
export PATH="$HOME/bin:$PATH"

# OpenClaw Completion
source "/Users/ivan_kalinichenko/.openclaw/completions/openclaw.zsh"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/ivan_kalinichenko/.lmstudio/bin"
# End of LM Studio CLI section

